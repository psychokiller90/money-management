# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=         # Ton user ID Telegram (sécurité : bot perso uniquement)

# Mistral
MISTRAL_API_KEY=           # console.mistral.ai

# Google Sheets
GOOGLE_CREDENTIALS_JSON=   # Contenu JSON du service account (stringifié)
SPREADSHEET_ID=            # ID du fichier Sheets (dans l'URL)

# Rappels & cron
REMINDER_DAYS=3            # Seuil (en jours) avant rappel
CRON_SECRET=               # Secret partagé avec cron-job.org pour /cron/reminder

# App
WEBHOOK_URL=               # URL publique Render (prod uniquement, sans slash final)
PORT=                      # Render injecte ça automatiquement
NODE_ENV=development

# Supabase (V2 — phase 0+)
SUPABASE_URL=                  # https://<project-ref>.supabase.co (PAS de /rest/v1, PAS de slash final)
SUPABASE_SERVICE_ROLE_KEY=     # Clé service_role (Dashboard → Project Settings → API)
SUPABASE_ANON_KEY=             # Clé anon/publishable (utile pour le keep-alive cron-job.org)
