{
  "name": "expense-bot",
  "version": "1.0.0",
  "description": "Telegram bot — photo facture → Mistral Vision → Google Sheets (V2 : + Supabase)",
  "main": "src/bot.js",
  "type": "module",
  "scripts": {
    "start": "node src/bot.js",
    "dev": "node --watch src/bot.js",
    "seed": "node scripts/seed-references.mjs",
    "migrate:dry": "node scripts/migrate-from-sheet.mjs --dry-run",
    "migrate:commit": "node scripts/migrate-from-sheet.mjs --commit",
    "migrate:verify": "node scripts/verify-migration.mjs"
  },
  "dependencies": {
    "@mistralai/mistralai": "^1.3.6",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "googleapis": "^171.0.0",
    "telegraf": "^4.16.3",
    "ws": "^8.18.0"
  }
}
